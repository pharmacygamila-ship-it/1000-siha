generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id         Int      @id @default(autoincrement())
  name       String
  cat        String
  price      Int
  disc       Int      @default(0)
  desc       String   @default("")
  tags       Json     @default("[]")
  img        String   @default("")
  images     Json     @default("[]")
  video      String   @default("")
  relatedIds Json     @default("[]")
  rating     Float    @default(0)
  reviews    Int      @default(0)
  sold       Int      @default(0)
  stock      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orderItems OrderItem[]
  gifts      Gift[]

  @@index([cat])
  @@index([sold])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  icon      String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id        String   @id
  name      String
  phone     String
  gov       String
  addr      String
  notes     String   @default("")
  total     Int
  status    String   @default("جديد")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        Int    @id @default(autoincrement())
  orderId   String
  productId Int
  qty       Int    @default(1)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

